{
  "name": "rt-flow",
  "displayName": "Runtime Flow",
  "description": "Runtime flow management · adaptive scheduling",
  "version": "17.41.0",
  "publisher": "devaid",
  "repository": { "type": "git", "url": "https://github.com/AiCodeHelper/rt-flow.git" },
  "homepage": "https://github.com/AiCodeHelper/rt-flow",
  "bugs": { "url": "https://github.com/AiCodeHelper/rt-flow/issues" },
  "keywords": ["runtime", "flow", "scheduling", "adaptive", "management"],
  "license": "MIT",
  "icon": "media/icon.png",
  "engines": { "vscode": "^1.85.0" },
  "categories": ["AI", "Other"],
  "activationEvents": ["onStartupFinished"],
  "main": "./extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "wam-container",
          "title": "RT Flow",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "wam-container": [
        {
          "id": "wam.panel",
          "name": "无感切号",
          "type": "webview"
        }
      ]
    },
    "commands": [
      { "command": "wam.openEditor", "title": "切号: 管理面板", "category": "RT Flow" },
      { "command": "wam.status", "title": "切号: 状态", "category": "RT Flow" },
      { "command": "wam.wamMode", "title": "切号: WAM 模式 (自动轮转)", "category": "RT Flow" },
      { "command": "wam.officialMode", "title": "切号: 官方登录模式 (暂停轮转)", "category": "RT Flow" },
      { "command": "wam.switchAccount", "title": "切号: 切换账号", "category": "RT Flow" },
      { "command": "wam.panicSwitch", "title": "切号: 紧急切换", "category": "RT Flow" },
      { "command": "wam.refreshAll", "title": "切号: 刷新全部", "category": "RT Flow" },
      { "command": "wam.addAccount", "title": "切号: 添加账号", "category": "RT Flow" },
      { "command": "wam.autoRotate", "title": "切号: 智能轮转", "category": "RT Flow" },
      { "command": "wam.injectToken", "title": "切号: 注入 Token", "category": "RT Flow" },
      { "command": "wam.verifyAll", "title": "切号: 验证清理 (剔除过期/无效号)", "category": "RT Flow" },
      { "command": "wam.scanExpiry", "title": "切号: 刷新有效期", "category": "RT Flow" },
      { "command": "wam.selfTest", "title": "切号: 自诊断", "category": "RT Flow" },
      { "command": "wam.diagWrite", "title": "切号: 写盘诊断", "category": "RT Flow" },
      { "command": "wam.restore", "title": "切号: 从归档恢复账号", "category": "RT Flow" },
      { "command": "wam.clearBlacklist", "title": "切号: 清空黑名单 (Devin 复活)", "category": "RT Flow" },
      { "command": "wam.testDevinSwitch", "title": "切号: 测试 Devin 链路", "category": "RT Flow" },
      { "command": "wam.checkUpdate", "title": "RT Flow: 检查更新", "category": "RT Flow" },
      { "command": "wam.verifyEndToEnd", "title": "全链路自检 (E2E)", "category": "RT Flow" }
    ],
    "configuration": {
      "title": "RT Flow",
      "properties": {
        "wam.autoRotate": {
          "type": "boolean",
          "default": true,
          "description": "额度变动时自动切到最优账号 (唯一用户开关 · 其他参数内化)"
        },
        "wam.productName": { "type": "string", "default": "", "description": "产品名 (留空=自动检测 Windsurf/Cursor/VSCode)" },
        "wam.dataDir": { "type": "string", "default": "", "description": "数据目录 (留空=自动检测)" },
        "wam.wamHotDir": { "type": "string", "default": "", "description": "v17.41 WAM 工作目录 (留空=~/.wam-hot · 亦可用 env WAM_HOT_DIR)" },
        "wam.relayHost": { "type": "string", "default": "", "description": "中继域名 (留空=禁用)" },
        "wam.firebase.extraKeys": { "type": "array", "items": { "type": "string" }, "default": [], "description": "追加Firebase API keys" },
        "wam.firebase.referer": { "type": "string", "default": "", "description": "Firebase Referer头" },
        "wam.officialEndpoints": { "type": "array", "items": { "type": "string" }, "default": [], "description": "追加官方API端点" },
        "wam.planStatusUrls": { "type": "array", "items": { "type": "string" }, "default": [], "description": "v17.41 完全覆盖 PlanStatus 端点列表 (空=用内置默认)" },
        "wam.registerUrl": { "type": "string", "default": "", "description": "v17.41 RegisterUser 端点 (留空=内置默认)" },
        "wam.chatCapacityUrl": { "type": "string", "default": "", "description": "v17.41 CheckChatCapacity 端点 (留空=内置默认)" },
        "wam.claudeProbeModel": { "type": "string", "default": "", "description": "v17.41 Claude 探测模型名 (留空=claude-sonnet-4-6)" },
        "wam.devin.loginUrl": { "type": "string", "default": "", "description": "v17.41 Devin 登录端点 (留空=内置默认)" },
        "wam.devin.postAuthUrl": { "type": "string", "default": "", "description": "v17.41 Devin PostAuth 端点 (留空=内置默认)" },
        "wam.injectCommands": { "type": "array", "items": { "type": "string" }, "default": [], "description": "覆盖注入命令列表" },
        "wam.proxy.scanPorts": { "type": "array", "items": { "type": "number" }, "default": [], "description": "v17.41 完全覆盖代理扫描端口列表 (空=内置默认)" },
        "wam.proxy.gatewayPorts": { "type": "array", "items": { "type": "number" }, "default": [], "description": "v17.41 完全覆盖网关扫描端口列表 (空=内置默认)" },
        "wam.proxy.extraPorts": { "type": "array", "items": { "type": "number" }, "default": [], "description": "追加代理扫描端口" },
        "wam.proxy.extraGatewayPorts": { "type": "array", "items": { "type": "number" }, "default": [], "description": "追加网关扫描端口" },
        "wam.monitorIntervalMs": { "type": "number", "default": 3000, "description": "监测间隔(ms)" },
        "wam.scanIntervalMs": { "type": "number", "default": 45000, "description": "扫描间隔(ms)" },
        "wam.tokenCacheTtlMin": { "type": "number", "default": 50, "description": "Token缓存TTL(分)" },
        "wam.autoSwitchThreshold": { "type": "number", "default": 5, "description": "自动切号阈值(%)" },
        "wam.predictiveThreshold": { "type": "number", "default": 25, "description": "预热阈值(%)" },
        "wam.injectFailCooldownMs": { "type": "number", "default": 3000, "description": "注入失败冷却(ms)" },
        "wam.purgeIntervalMs": { "type": "number", "default": 21600000, "description": "自动清理间隔(ms)" },
        "wam.proxyCacheTtlMs": { "type": "number", "default": 300000, "description": "代理缓存TTL(ms)" },
        "wam.proxyFailTtlMs": { "type": "number", "default": 30000, "description": "代理失败缓存(ms)" },
        "wam.claimsCacheTtlMs": { "type": "number", "default": 5000, "description": "claims缓存TTL(ms)" },
        "wam.quotaMinIntervalMs": { "type": "number", "default": 10000, "description": "额度查询间隔(ms)" },
        "wam.quota429BackoffMs": { "type": "number", "default": 60000, "description": "429退避(ms)" },
        "wam.relayIpTtlMs": { "type": "number", "default": 600000, "description": "Relay IP缓存(ms)" },
        "wam.tokenPool.burstMs": { "type": "number", "default": 5000, "description": "Pool冲刺间隔(ms)" },
        "wam.tokenPool.cruiseMs": { "type": "number", "default": 45000, "description": "Pool巡航间隔(ms)" },
        "wam.tokenPool.burstDurationMs": { "type": "number", "default": 180000, "description": "Pool冲刺时长(ms)" },
        "wam.tokenPool.marginMs": { "type": "number", "default": 600000, "description": "Token续期边距(ms)" },
        "wam.tokenPool.parallelBurst": { "type": "number", "default": 3, "description": "冲刺并行度" },
        "wam.tokenPool.parallelCruise": { "type": "number", "default": 1, "description": "巡航并行度" },
        "wam.tokenPool.tempBanThreshold": { "type": "number", "default": 3, "description": "拉黑阈值" },
        "wam.tokenPool.tempBanDurationMs": { "type": "number", "default": 900000, "description": "拉黑时长(ms)" },
        "wam.scanBatchSize": { "type": "number", "default": 10, "description": "扫描批次大小" },
        "wam.changeThreshold": { "type": "number", "default": 0.01, "description": "变动检测阈值(%)" },
        "wam.inUseCooldownMs": { "type": "number", "default": 120000, "description": "使用标记冷却(ms)" },
        "wam.burstIntervalMs": { "type": "number", "default": 1500, "description": "突发轮询间隔(ms)" },
        "wam.burstDurationMs": { "type": "number", "default": 60000, "description": "突发持续时长(ms)" },
        "wam.dailyResetHourUtc": { "type": "number", "default": 8, "description": "日配额重置(UTC时)" },
        "wam.weeklyResetDay": { "type": "number", "default": 0, "description": "周配额重置(0=周日)" },
        "wam.waitResetHours": { "type": "number", "default": 3, "description": "重置等待(小时)" },
        "wam.instanceHeartbeatMs": { "type": "number", "default": 30000, "description": "实例心跳(ms)" },
        "wam.instanceDeadMs": { "type": "number", "default": 60000, "description": "实例死亡判定(ms)" },
        "wam.switchCooldownMs": { "type": "number", "default": 15000, "description": "切号冷却(ms)" },
        "wam.rateLimitCooldownMs": { "type": "number", "default": 10000, "description": "限速检测冷却(ms)" },
        "wam.droughtCacheTtlMs": { "type": "number", "default": 10000, "description": "干旱缓存TTL(ms)" },
        "wam.autoUpdate.enabled": { "type": "boolean", "default": true, "description": "v17.10 autoUpdate: 启用自动更新" },
        "wam.autoUpdate.autoDiscover": { "type": "boolean", "default": true, "description": "v17.17 autoDiscover: source 未配置时默认走公开 jsDelivr 镜像 fallback (cdn→fastly→gcore→testingcf)" },
        "wam.autoUpdate.source": { "type": "string", "default": "", "description": "autoUpdate 源: SMB 路径 或 HTTPS URL (空 = 走默认公开 jsDelivr 主仓)" },
        "wam.autoUpdate.checkIntervalMs": { "type": "number", "default": 3600000, "description": "autoUpdate 检查间隔 (默认 1h·最小 1min)" },
        "wam.autoUpdate.startDelayMs": { "type": "number", "default": 10000, "description": "启动后首次 autoUpdate 延迟 (ms)" },
        "wam.autoUpdate.notifyUser": { "type": "boolean", "default": false, "description": "v17.10 完成自更新后是否弹窗通知用户 (太上不知有之默认静默)" },
        "wam._origin_removed": { "type": "string", "default": "v17.36 剥离", "description": "v17.36 · origin 设置已移至 020-道VSIX_DaoAgi", "deprecationMessage": "v17.36 · origin 设置已移至独立插件" },
        "wam.messageAnchor.enabled": { "type": "boolean", "default": true, "description": "v17.39 消息锚定: 对话发送检测 → 立即切号 (反者道之动 · 外部 API 失效亦不影响)" },
        "wam.messageAnchor.debounceMs": { "type": "number", "default": 1500, "description": "v17.39 消息锚定: 检测到 send 后延后切号的 ms (默认 1500 让当前流完成)" },
        "wam.messageAnchor.everyN": { "type": "number", "default": 1, "description": "v17.39 消息锚定: 每 N 次 send 切一次 (默认 1 = 每次)" },
        "wam.messageAnchor.dedupeMs": { "type": "number", "default": 300, "description": "v17.39 消息锚定: 多路并发命中去重窗口 (ms)" },
        "wam.messageAnchor.path.network": { "type": "boolean", "default": true, "description": "v17.39 路径A · https.request 嗅探 cascade 流量" },
        "wam.messageAnchor.path.command": { "type": "boolean", "default": true, "description": "v17.39 路径B · executeCommand 嗅探 cascade 命令" },
        "wam.messageAnchor.path.cascade": { "type": "boolean", "default": true, "description": "v17.39 路径C · ~/.codeium/windsurf/cascade/*.pb 文件监听" },
        "wam.preferDevinFirst": { "type": "boolean", "default": true, "description": "v17.40 万法归宗: 未知账号默认直走 Devin · 跳过 16s Firebase 超时 (Firebase 明确标记账号仍走 Firebase)" },
        "wam.firebaseMaxTimeoutMs": { "type": "number", "default": 4000, "description": "v17.40 Firebase 整体超时上限 (ms) · 快失败让 Devin 兜底登场" }
      }
    }
  }
}
