{
	"name": "windsurf-login-helper",
	"displayName": "Windsurf Login Helper",
	"description": "Windsurf Account Manager v10 — 道法自然: 纯热替换·绝不logout·绝不杀agent·Token预热·Rate-limit拦截·智能轮转·零中断",
	"version": "10.0.5",
	"license": "MIT",
	"engines": {
		"vscode": "^1.85.0"
	},
	"categories": [
		"Other"
	],
	"activationEvents": [
		"onStartupFinished"
	],
	"main": "./dist/extension.js",
	"contributes": {
		"viewsContainers": {
			"activitybar": [
				{
					"id": "windsurf-login",
					"title": "Windsurf Login",
					"icon": "media/icon.svg"
				}
			]
		},
		"views": {
			"windsurf-login": [
				{
					"id": "windsurf-login.loginView",
					"name": "Login",
					"type": "webview"
				}
			]
		},
		"commands": [
			{
				"command": "wam.switchAccount",
				"title": "切换账号",
				"category": "Windsurf Login"
			},
			{
				"command": "wam.refreshCredits",
				"title": "刷新积分",
				"category": "Windsurf Login"
			},
			{
				"command": "wam.openPanel",
				"title": "打开管理面板",
				"category": "Windsurf Login"
			},
			{
				"command": "wam.switchMode",
				"title": "切换模式 (本地/中转)",
				"category": "Windsurf Login"
			},
			{
				"command": "wam.reprobeProxy",
				"title": "重新探测代理",
				"category": "Windsurf Login"
			},
			{
				"command": "wam.resetFingerprint",
				"title": "重置设备指纹",
				"category": "Windsurf Login"
			},
			{
				"command": "wam.panicSwitch",
				"title": "紧急切换 (限流应急)",
				"category": "Windsurf Login"
			},
			{
				"command": "wam.batchAdd",
				"title": "批量添加账号",
				"category": "Windsurf Login"
			},
			{
				"command": "wam.refreshAllCredits",
				"title": "刷新全部积分并轮转",
				"category": "Windsurf Login"
			},
			{
				"command": "wam.smartRotate",
				"title": "智能轮转 (查全部·切最优)",
				"category": "Windsurf Login"
			},
			{
				"command": "wam.importAccounts",
				"title": "导入账号",
				"category": "Windsurf Login"
			},
			{
				"command": "wam.initWorkspace",
				"title": "工作区配置 (智慧部署+源启动)",
				"category": "Windsurf Login"
			}
		],
		"configuration": {
			"title": "无感切号",
			"properties": {
				"wam.autoRotate": {
					"type": "boolean",
					"default": true,
					"description": "积分不足时自动切换到最高积分账号"
				},
				"wam.rotateFingerprint": {
					"type": "boolean",
					"default": true,
					"description": "切号时自动轮转设备指纹 (防止服务端关联多账号到同一设备)"
				}
			}
		}
	},
	"__metadata": {
		"installedTimestamp": 1775020170514,
		"targetPlatform": "undefined",
		"size": 4487064
	}
}
