accounts.json
keypool.json
oneshot_token.json
inject_result.json
quota_snapshots.json
inuse_marks.json
instance_claims.json

# ═══ 机密 ═══
.env
.env.local
secrets.env
*.pem
*.key

# ═══ 构建产物 ═══
*.vsix
node_modules/
dist/

# ═══ 临时与日志 ═══
*.log
*.bak
__pycache__/
.vsixmanifest

# ═══ 运行时持态 · 不入库 ═══
