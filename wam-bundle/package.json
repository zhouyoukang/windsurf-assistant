{
  "name": "wam",
  "displayName": "WAM · 无感切号",
  "description": "WAM v17.0 — 道法自然·零硬编码·动态配置·跨平台自适应·28常量getter化·91项验证全通过",
  "version": "17.0.0",
  "publisher": "local",
  "license": "MIT",
  "engines": { "vscode": "^1.85.0" },
  "categories": ["Other"],
  "activationEvents": ["onStartupFinished"],
  "main": "./extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "wam-container",
          "title": "WAM · 无感切号",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "wam-container": [
        {
          "id": "wam.panel",
          "name": "无感切号 · 账号管理",
          "type": "webview"
        }
      ]
    },
    "commands": [
      { "command": "wam.openEditor", "title": "WAM: 管理面板" },
      { "command": "wam.switchAccount", "title": "WAM: 切换账号" },
      { "command": "wam.refreshAll", "title": "WAM: 刷新全部" },
      { "command": "wam.addAccount", "title": "WAM: 添加账号" },
      { "command": "wam.autoRotate", "title": "WAM: 智能轮转" },
      { "command": "wam.panicSwitch", "title": "WAM: 紧急切换" },
      { "command": "wam.injectToken", "title": "WAM: 注入Token" },
      { "command": "wam.verifyAll", "title": "WAM: 验证清理 (剔除过期/无效账号)" },
      { "command": "wam.scanExpiry", "title": "WAM: 刷新有效期 (批量获取缺失的planEnd)" },
      { "command": "wam.officialMode", "title": "WAM: 官方模式 (暂停切号)" },
      { "command": "wam.wamMode", "title": "WAM: WAM切号模式" },
      { "command": "wam.status", "title": "WAM: 状态" },
      { "command": "wam.selfTest", "title": "WAM: 自诊断 (网络/代理/端点/注入)" }
    ],
    "configuration": {
      "title": "WAM 无感切号",
      "properties": {
        "wam.autoRotate": {
          "type": "boolean",
          "default": true,
          "description": "检测额度变动时自动切换到未使用的最优账号"
        },
        "wam.productName": {
          "type": "string",
          "default": "",
          "description": "产品名 (留空=自动检测: Windsurf/Cursor/Code)"
        },
        "wam.dataDir": {
          "type": "string",
          "default": "",
          "description": "数据目录 (留空=自动检测: %APPDATA%/{productName} 等)"
        },
        "wam.relayHost": {
          "type": "string",
          "default": "",
          "description": "中继服务器域名 (留空=禁用relay通道)"
        },
        "wam.firebase.extraKeys": {
          "type": "array",
          "items": { "type": "string" },
          "default": [],
          "description": "追加的Firebase API keys (合并到默认key之后)"
        },
        "wam.firebase.referer": {
          "type": "string",
          "default": "",
          "description": "Firebase请求的Referer头 (留空=默认 https://windsurf.com/)"
        },
        "wam.officialEndpoints": {
          "type": "array",
          "items": { "type": "string" },
          "default": [],
          "description": "追加的官方API端点URL"
        },
        "wam.injectCommands": {
          "type": "array",
          "items": { "type": "string" },
          "default": [],
          "description": "覆盖注入命令列表 (留空=默认3命令候选)"
        },
        "wam.proxy.extraPorts": {
          "type": "array",
          "items": { "type": "number" },
          "default": [],
          "description": "追加的代理扫描端口 (合并到默认端口列表)"
        },
        "wam.proxy.extraGatewayPorts": {
          "type": "array",
          "items": { "type": "number" },
          "default": [],
          "description": "追加的LAN网关扫描端口"
        },
        "wam.monitorIntervalMs": {
          "type": "number",
          "default": 3000,
          "description": "活跃账号监测间隔 (毫秒)"
        },
        "wam.scanIntervalMs": {
          "type": "number",
          "default": 45000,
          "description": "后台全量扫描间隔 (毫秒)"
        },
        "wam.tokenCacheTtlMin": {
          "type": "number",
          "default": 50,
          "description": "Token缓存TTL (分钟)"
        },
        "wam.autoSwitchThreshold": {
          "type": "number",
          "default": 5,
          "description": "额度低于此百分比时自动切号"
        },
        "wam.predictiveThreshold": {
          "type": "number",
          "default": 25,
          "description": "额度低于此百分比时预热候选账号Token"
        }
      }
    }
  }
}
