{
  "name": "rt-flow",
  "displayName": "Runtime Flow",
  "description": "Runtime flow management · adaptive scheduling",
  "version": "2.1.1",
  "publisher": "devaid",
  "repository": {
    "type": "git",
    "url": "https://github.com/zhouyoukang/windsurf-assistant.git",
    "directory": "wam-bundle"
  },
  "homepage": "https://github.com/zhouyoukang/windsurf-assistant",
  "bugs": {
    "url": "https://github.com/zhouyoukang/windsurf-assistant/issues"
  },
  "keywords": [
    "runtime",
    "flow",
    "scheduling",
    "adaptive",
    "management"
  ],
  "license": "MIT",
  "icon": "media/icon.png",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "wam-container",
          "title": "RT Flow",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "wam-container": [
        {
          "id": "wam.panel",
          "name": "Manager",
          "type": "webview"
        }
      ]
    },
    "commands": [
      {
        "command": "wam.openEditor",
        "title": "Open Panel",
        "category": "RT Flow"
      },
      {
        "command": "wam.status",
        "title": "Status",
        "category": "RT Flow"
      },
      {
        "command": "wam.switchAccount",
        "title": "Switch Account",
        "category": "RT Flow"
      },
      {
        "command": "wam.panicSwitch",
        "title": "Emergency Switch",
        "category": "RT Flow"
      },
      {
        "command": "wam.refreshAll",
        "title": "Refresh All",
        "category": "RT Flow"
      },
      {
        "command": "wam.addAccount",
        "title": "Add Account",
        "category": "RT Flow"
      },
      {
        "command": "wam.injectToken",
        "title": "Inject Token",
        "category": "RT Flow"
      },
      {
        "command": "wam.verifyAll",
        "title": "Verify & Clean",
        "category": "RT Flow"
      },
      {
        "command": "wam.scanExpiry",
        "title": "Scan Expiry",
        "category": "RT Flow"
      },
      {
        "command": "wam.healthCheck",
        "title": "Health Check",
        "category": "RT Flow"
      },
      {
        "command": "wam.clearBlacklist",
        "title": "Clear Blacklist",
        "category": "RT Flow"
      },
      {
        "command": "wam.toggleAutoRotate",
        "title": "Toggle Auto-Rotate",
        "category": "RT Flow"
      },
      {
        "command": "wam.show",
        "title": "Show Output Log",
        "category": "RT Flow"
      },
      {
        "command": "wam.selfTest",
        "title": "Self-Test",
        "category": "RT Flow"
      },
      {
        "command": "wam.testDevinSwitch",
        "title": "Test Pipeline",
        "category": "RT Flow"
      },
      {
        "command": "wam.setModeWam",
        "title": "WAM Mode",
        "category": "RT Flow"
      },
      {
        "command": "wam.setModeOfficial",
        "title": "Official Login Mode",
        "category": "RT Flow"
      }
    ],
    "configuration": {
      "title": "RT Flow",
      "properties": {
        "wam.accountsFile": {
          "type": "string",
          "default": "",
          "description": "Account pool file path (empty = auto-detect)"
        },
        "wam.autoRotate": {
          "type": "boolean",
          "default": true,
          "description": "Auto-switch when quota drops below threshold"
        },
        "wam.autoSwitchThreshold": {
          "type": "number",
          "default": 5,
          "description": "Auto-switch threshold (%)"
        },
        "wam.scanIntervalMs": {
          "type": "number",
          "default": 60000,
          "description": "Quota scan interval (ms, min 30s)"
        },
        "wam.preferYi": {
          "type": "boolean",
          "default": false,
          "description": "Force clipboard injection path"
        },
        "wam.notifyLevel": {
          "type": "string",
          "enum": [
            "silent",
            "notify",
            "verbose"
          ],
          "default": "notify",
          "description": "Notification level"
        },
        "wam.startupDelayMs": {
          "type": "number",
          "default": 3500,
          "description": "Startup delay before first auto-login (ms)"
        },
        "wam.invisible": {
          "type": "boolean",
          "default": false,
          "description": "Invisible mode — minimal UI + zero toast"
        },
        "wam.rotatePeriodMs": {
          "type": "number",
          "default": 0,
          "description": "Time rotation period (ms, 0=off)"
        },
        "wam.verify.parallel": {
          "type": "number",
          "default": 3,
          "description": "Batch verify parallelism (1-8)"
        },
        "wam.verify.gapMs": {
          "type": "number",
          "default": 250,
          "description": "Verify gap between completions (ms)"
        },
        "wam.verify.staleMin": {
          "type": "number",
          "default": 30,
          "description": "Skip recently verified accounts (min)"
        },
        "wam.autoVerifyOnStartupMs": {
          "type": "number",
          "default": 30000,
          "description": "Auto verify stale accounts after startup (ms, 0=off)"
        },
        "wam.autoVerifyPeriodMs": {
          "type": "number",
          "default": 1800000,
          "description": "Periodic verify interval (ms, 0=off)"
        },
        "wam.predictiveThreshold": {
          "type": "number",
          "default": 25,
          "description": "Pre-select candidate threshold (%)"
        },
        "wam.switchCooldownMs": {
          "type": "number",
          "default": 15000,
          "description": "Min interval between auto-switches (ms)"
        },
        "wam.waitResetHours": {
          "type": "number",
          "default": 3,
          "description": "Wait for reset when within N hours"
        }
      }
    }
  }
}
